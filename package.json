{
  "name": "sp-aie-theazec34-project",
  "version": "0.5.0",
  "private": true,
  "description": "Brasaland — fusión Hito 1 (web) + Hito 2 (TypeScript) + Hito 3 (Talent Tracker) — rama 3.5",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "demo": "npm run build && node dist/demo.js",
    "serve:web": "npx --yes http-server . -p 8080 -o portal.html -a 127.0.0.1",
